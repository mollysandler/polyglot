# Copy to .env and fill in real values. .env is gitignored.

# Deepgram (ASR + diarization)
DEEPGRAM_API_KEY=

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=

# Google Cloud Translate — path to service-account JSON
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: TTS provider override (default: elevenlabs)
# TTS_PROVIDER=elevenlabs

# Optional: disable speaker clustering (use Deepgram's raw speaker_id)
# ENABLE_SPEAKER_CLUSTERING=0
